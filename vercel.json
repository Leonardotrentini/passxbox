{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/t/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/passxbox/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/cardpass/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/preview-raspadinha",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
